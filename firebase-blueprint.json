{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number", "description": "timestamp" }
      },
      "required": ["email", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation thread.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model", "system"] },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["role", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "The user profile."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "Chat",
      "description": "A user's chat sessions."
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat session."
    }
  }
}
